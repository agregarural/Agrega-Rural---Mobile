<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    >

    <!-- Header verde -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnVoltar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Voltar"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meu perfil"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Conteúdo rolável -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="88dp"
        android:layout_marginBottom="60dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Foto de perfil -->
            <FrameLayout
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center_horizontal">


                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/imgPerfil"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:src="@drawable/ic_avatar_placeholder"
                    app:civ_border_width="3dp"
                    app:civ_border_color="#E0E0E0" />

                <!-- Botão editar foto -->
                <ImageView
                    android:id="@+id/btnEditarFoto"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_editar_foto"
                    android:background="@drawable/bg_circle_white"
                    android:padding="4dp"
                    android:layout_gravity="bottom|end"
                    android:contentDescription="Editar foto" />
            </FrameLayout>

            <!-- Nome do usuário -->

            <!-- Cards -->
            <TextView
                android:id="@+id/tvNomeUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="Murilo Gomes Carvalho Góes"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <!-- Meus Pedidos -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMeusPedidos"
                    android:layout_width="120dp"
                    android:layout_height="100dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#F5F5F5"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_meus_pedidos"
                            android:contentDescription="Meus Pedidos" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Meus\npedidos"
                            android:textSize="12sp"
                            android:textColor="#333333"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Minha Cooperativa -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMinhaCooperativa"
                    android:layout_width="120dp"
                    android:layout_height="100dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#F5F5F5"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_minha_cooperativa"
                            android:contentDescription="Minha Cooperativa" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Minha\nCooperativa"
                            android:textSize="12sp"
                            android:textColor="#333333"
                            android:gravity="center"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginTop="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" />

            <!-- Lista de opções -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp">

                <!-- Dados pessoais -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDadosPessoais"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp"
                    app:strokeColor="#DDDDDD"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dados pessoais"
                            android:textSize="15sp"
                            android:textColor="#222222"
                            android:layout_centerVertical="true"/>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:tint="#888888"
                            android:contentDescription="Navegar" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Endereços -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardEnderecos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp"
                    app:strokeColor="#DDDDDD"
                    app:strokeWidth="1dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:text="Endereços"
                            android:textSize="15sp"
                            android:textColor="#222222"
                            android:layout_centerVertical="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:tint="#888888"
                            android:contentDescription="Navegar" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Cartões -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCartoes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp"
                    app:strokeColor="#DDDDDD"
                    app:strokeWidth="1dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:text="Cartões"
                            android:textSize="15sp"
                            android:textColor="#222222"
                            android:layout_centerVertical="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:tint="#888888"
                            android:contentDescription="Navegar" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- Atendimento ao Cliente(SAC) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSAC"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardElevation="0dp"
                    app:strokeColor="#DDDDDD"
                    app:strokeWidth="1dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:text="Atendimento ao Cliente(SAC)"
                            android:textSize="15sp"
                            android:textColor="#222222"
                            android:layout_centerVertical="true"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:tint="#888888"
                            android:contentDescription="Navegar" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- (continua igual para os outros cards...) -->

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>




</androidx.coordinatorlayout.widget.CoordinatorLayout>