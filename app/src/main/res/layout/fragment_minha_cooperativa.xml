<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7FF">

    <!-- Logo da cooperativa no fundo -->
    <ImageView
        android:id="@+id/bg"
        android:layout_width="430dp"
        android:layout_height="430dp"
        android:alpha="0.22"
        android:scaleType="centerCrop"
        android:src="@drawable/fundo_cooperativa"
        android:contentDescription="Logo da cooperativa"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- TOPO -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnVoltar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Voltar"
            app:tint="#FFFFFF" />

        <TextView
            android:text="Minha Cooperativa"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- CONTEÚDO -->
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- CARDS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="170dp"
            android:gravity="center">

            <!-- LINHA 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- CARD COOPERADOS -->
                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@drawable/card_bg"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="50dp">

                    <TextView
                        android:id="@+id/txtCooperados"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/green"
                        android:textStyle="bold"
                        android:textSize="25sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cooperados"
                        android:gravity="center"
                        android:textColor="@color/botoes"
                        android:textSize="20sp" />

                </LinearLayout>

                <!-- CARD ESTADOS -->
                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@drawable/card_bg"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtEstadosAtuacao"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/green"
                        android:textStyle="bold"
                        android:textSize="25sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estados de\natuação"
                        android:gravity="center"
                        android:textColor="@color/botoes"
                        android:textSize="20sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- LINHA 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="10dp">

                <!-- CARD IDADE -->
                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@drawable/card_bg"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_marginEnd="50dp">

                    <TextView
                        android:id="@+id/txtIdadeCooperativa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ANOS"
                        android:textColor="@color/green"
                        android:textStyle="bold"
                        android:textSize="25sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="De fundação"
                        android:gravity="center"
                        android:textColor="@color/botoes"
                        android:textSize="20sp" />

                </LinearLayout>

                <!-- CARD PRODUTOS -->
                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@drawable/card_bg"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtQuantidadeProdutos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/green"
                        android:textStyle="bold"
                        android:textSize="25sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Produtos no\ncatálogo"
                        android:gravity="center"
                        android:textColor="@color/botoes"
                        android:textSize="20sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- BOTÃO CONTATO -->
        <LinearLayout
            android:id="@+id/cardcontato"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/card_bg"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Contatos da cooperativa"
                android:textSize="15sp" />

            <ImageView
                android:contentDescription="Avançar"
                android:src="@drawable/ic_arrow_back"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:rotation="180" />

        </LinearLayout>

    </LinearLayout>

    <!-- MENU INFERIOR -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_marginBottom="5dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@drawable/navigatebar_shape">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:rowCount="1"
            android:layout_gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHome"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_columnWeight="1"
                android:contentDescription="Home"
                app:icon="@drawable/nvbar_home"
                app:iconSize="20dp"
                android:background="@color/transparent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCarrinho"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_columnWeight="1"
                android:contentDescription="Carrinho"
                app:icon="@drawable/nvbar_carrinho"
                app:iconSize="20dp"
                android:background="@color/transparent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEntrega"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_columnWeight="1"
                android:contentDescription="Entrega"
                app:icon="@drawable/nvbar_truck"
                app:iconSize="20dp"
                android:background="@color/transparent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnmenu"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_columnWeight="1"
                android:contentDescription="Menu"
                app:icon="@drawable/nvbar_menu"
                app:iconSize="20dp"
                android:background="@color/transparent" />

        </GridLayout>

    </com.google.android.material.bottomnavigation.BottomNavigationView>

</androidx.constraintlayout.widget.ConstraintLayout>