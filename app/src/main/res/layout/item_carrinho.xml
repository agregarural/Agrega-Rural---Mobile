<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="15dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <CheckBox
            android:id="@+id/checkboxCarrinho"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent
"
            app:layout_constraintEnd_toStartOf="@+id/imgProdutoCarrinho"/>

        <ImageView
            android:id="@+id/imgProdutoCarrinho"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/prod_racoeszardo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/checkboxCarrinho"
            />

        <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@+id/imgProdutoCarrinho">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:background="@color/green"
                android:padding="2dp">


                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMenos"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:layout_marginEd="20dp"
                    android:background="@drawable/icon_btn_mais"
                    android:contentDescription="btnMais"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/quantidadeProduto"
                    tools:layout_editor_absoluteY="5dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnMais"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:background="@drawable/icon_btn_menos"
                    android:contentDescription="Botão Somar"
                    app:layout_constraintEnd_toStartOf="@+id/quantidadeProduto"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toStartOf="parent"
                    tools:layout_editor_absoluteY="4dp" />

                <TextView
                    android:id="@+id/quantidadeProduto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textColor="#1B1B1B"
                    android:textSize="11dp"
                    app:layout_constraintEnd_toStartOf="@+id/btnMenos"
                    app:layout_constraintHorizontal_bias="0.5"
                    app:layout_constraintStart_toEndOf="@+id/btnMais"
                    tools:layout_editor_absoluteY="4dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>



</androidx.cardview.widget.CardView>