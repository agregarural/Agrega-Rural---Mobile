<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProduto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    android:layout_margin="25dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        >

        <ImageView
            android:id="@+id/imgItem"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/prod_racoeszardo"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:id="@+id/nomeItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rações Zardo"
            android:textStyle="bold"
            android:textSize="20dp"/>

        <TextView
            android:id="@+id/especificacaoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Saco 25KG"/>

        <TextView
            android:id="@+id/precoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="25dp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:text="R$500,00"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>