<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardProduto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    android:layout_margin="25dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <ImageView
            android:id="@+id/imgItem"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/prod_racoeszardo"

            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/nomeItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/racoes_zardo"
            android:textStyle="bold"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/especificacaoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/saco25kg" />

        <TextView
            android:id="@+id/precoNormalItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cliente_normal_exemplo"
            android:textSize="13sp"
            android:textColor="#777777"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txtDescontoCooperadoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/desconto_cooperado_exemplo"
            android:textSize="13sp"
            android:textColor="@color/green"
            android:visibility="gone" />

        <TextView
            android:id="@+id/precoItem"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:text="@string/precoexemplo2" />

    </LinearLayout>

</androidx.cardview.widget.CardView>