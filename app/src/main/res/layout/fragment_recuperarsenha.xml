<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RecuperarSenhaFragment">

    <FrameLayout
        android:id="@+id/frame1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/bg_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/img_fundo"
            tools:layout_editor_absoluteX="40dp"
            tools:layout_editor_absoluteY="50dp" />

        <View
            android:id="@+id/sombra"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#88000000" />
    </FrameLayout>

    <TextView
        android:id="@+id/titulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="30dp"
        android:layout_marginTop="80dp"
        android:text="@string/recuperacao"
        android:textColor="@color/white"
        android:textSize="35sp"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/frame2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <ImageView
            android:id="@+id/caixa_flut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="-120dp"
            android:src="@drawable/caixa_flutuante" />

        <LinearLayout
            android:id="@+id/linear1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/bt_voltar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="40dp"
                    android:layout_marginTop="30dp"
                    android:background="@null"
                    android:src="@drawable/bt_return" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="-12dp"
                    android:layout_marginTop="38dp"
                    android:text="@string/voltar"
                    android:textColor="@color/botoes"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="-1dp"
                android:text="@string/informar"
                android:textSize="20sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/cx_recuperar"
                android:layout_width="380dp"
                android:layout_height="45dp"
                android:layout_marginLeft="18dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_caixastxt"
                android:hint="@string/ins_email" />

            <Button
                android:id="@+id/bt_enviar"
                android:layout_width="380dp"
                android:layout_height="55dp"
                android:layout_marginLeft="16dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/botoes"
                android:fontFamily="sans-serif"
                android:text="@string/enviar"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>