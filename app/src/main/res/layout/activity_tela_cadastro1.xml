<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TelaCadastro1">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/frame1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        >
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/img_fundo"
            tools:layout_editor_absoluteX="40dp"
            tools:layout_editor_absoluteY="50dp"
            android:id="@+id/bg_img"
            />
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#88000000"
            android:id="@+id/sombra"/>
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/cadastro"
        android:textSize="35sp"
        android:textColor="@color/white"
        android:fontFamily="sans-serif"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="30dp"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="80dp"
        app:layout_constraintRight_toRightOf="parent"
        android:id="@+id/titulo"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:id="@+id/frame2">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:src="@drawable/caixa_flutuante"
            android:layout_marginBottom="-120dp"
            android:id="@+id/caixa_flut"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/linear1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/bt_return"
                    android:background="@null"
                    android:layout_marginLeft="40dp"
                    android:layout_marginTop="30dp"
                    android:id="@+id/bt_voltar"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/voltar"
                    android:textSize="18sp"
                    android:textColor="@color/botoes"
                    android:layout_marginTop="38dp"
                    android:layout_marginLeft="-12dp"
                    android:textStyle="bold"
                    />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nome_pes"
                android:textSize="18sp"
                android:textColor="@color/botoes"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="20dp"
                />

            <EditText
                android:layout_width="380dp"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:layout_marginLeft="18dp"
                android:hint="@string/nome_completo"
                android:background="@drawable/bg_caixastxt"
                android:id="@+id/cx_nome"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email"
                android:textSize="18sp"
                android:textColor="@color/botoes"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="20dp"
                />

            <EditText
                android:layout_width="380dp"
                android:layout_height="45dp"
                android:layout_marginTop="5dp"
                android:layout_marginLeft="18dp"
                android:hint="@string/email"
                android:background="@drawable/bg_caixastxt"
                android:id="@+id/cx_email"
                />

            <Button
                android:id="@+id/bt_continuar"
                android:layout_width="380dp"
                android:layout_height="55dp"
                android:layout_marginLeft="16dp"
                android:backgroundTint="@color/botoes"
                android:fontFamily="sans-serif"
                android:text="@string/continuar"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>


        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>