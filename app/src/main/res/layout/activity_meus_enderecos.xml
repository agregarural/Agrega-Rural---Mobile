<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
xmlns:tools="http://schemas.android.com/tools"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="#FFFFFF"
tools:context=".MeusEnderecos">

<!-- Header verde -->
<LinearLayout
    android:id="@+id/header"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_header_gradient"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="40dp"
    android:paddingBottom="16dp">

    <ImageView
        android:id="@+id/btnVoltar"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="Voltar"
        app:tint="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Meus endereços"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginStart="8dp" />
</LinearLayout>

<!-- Conteúdo -->
<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="88dp"
    android:layout_marginBottom="60dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Endereços"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginBottom="16dp" />

        <!-- Endereço 1 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEndereco1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="0dp"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvEndereco1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rua das Hortências, 228 – Centro\nMuniz Freire – ES, 29380-000"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/btnEditarEndereco1"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/btnEditarEndereco1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_editar_foto"
                    android:padding="6dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="Editar endereço" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Endereço 2 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEndereco2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardElevation="0dp"
            app:strokeColor="#DDDDDD"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvEndereco2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avenida Rio Verde, 951 – Nova\nBrasilia Xique-Xique – BA,\n47400-000"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/btnEditarEndereco2"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/btnEditarEndereco2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_editar_foto"
                    android:padding="6dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="Editar endereço" />
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/adicionar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:padding="10dp"
            android:src="@drawable/ic_add"
            app:shapeAppearanceOverlay="@style/CircleImageStyle"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="3dp" />

    </LinearLayout>



</androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:background="#1B5E20"
        android:orientation="horizontal"
        android:weightSum="4">

        <!-- Início -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/nvbar_home"
                android:contentDescription="Início"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Início"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Carrinho -->
        <LinearLayout
            android:id="@+id/navCarrinho"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/nvbar_carrinho"
                android:contentDescription="Carrinho"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Carrinho"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Entrega -->
        <LinearLayout
            android:id="@+id/navEntrega"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/nvbar_truck"
                android:contentDescription="Entrega"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrega"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Menu -->
        <LinearLayout
            android:id="@+id/navMenu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/nvbar_menu"
                android:contentDescription="Menu"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>