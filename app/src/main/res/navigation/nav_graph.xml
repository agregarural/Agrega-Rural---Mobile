<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/telaInicialFragment">

    <fragment
        android:id="@+id/telaInicialFragment"
        android:name="com.mobile.agregarural.ui.common.TelaInicial"
        tools:layout="@layout/fragment_inicial">
        <action
            android:id="@+id/action_inicio_to_login"
            app:destination="@id/telaLoginFragment" />
        <action
            android:id="@+id/action_inicio_to_cadastro"
            app:destination="@id/telaCadastro1Fragment" />
    </fragment>
    <fragment
        android:id="@+id/categoriaProdutosFragment"
        android:name="com.mobile.agregarural.ui.cooperative.CategoriaProdutosFragment"
        android:label="Produtos da Categoria"
        tools:layout="@layout/fragment_categoria_produtos" />
    <fragment
        android:id="@+id/TelaContatosCoopFragment"
        android:name="com.mobile.agregarural.ui.cooperative.ContatosCoop" />

    <fragment
        android:id="@+id/TelaSacFragment"
        android:name="com.mobile.agregarural.ui.chat.ChatFragment" />


    <fragment
        android:id="@+id/homeFragment"
        android:name="com.mobile.agregarural.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_menuFragment"
            app:destination="@id/menuFragment" />
        <action
            android:id="@+id/action_homeFragment_to_perfilFragment"
            app:destination="@id/perfilFragment" />
        <action
            android:id="@+id/action_homeFragment_to_telaProdutoFragment"
            app:destination="@id/telaProdutoFragment" />
        <action
            android:id="@+id/action_homeFragment_to_meusPedidosFragment"
            app:destination="@id/meusPedidosFragment" />

    </fragment>

    <fragment
        android:id="@+id/perfilFragment"
        android:name="com.mobile.agregarural.ui.profile.PerfilFragment"
        android:label="Perfil"
        tools:layout="@layout/fragment_perfil">

        <action
            android:id="@+id/action_perfilFragment_to_meusEnderecosFragment"
            app:destination="@id/meusEnderecosFragment" />
        <action
            android:id="@+id/action_perfilFragment_to_dadosPessoaisFragment"
            app:destination="@id/dadosPessoaisFragment" />
        <action
            android:id="@+id/action_perfilFragment_to_meusPedidosFragment"
            app:destination="@id/meusPedidosFragment" />
        <action
            android:id="@+id/action_homeFragment_to_telaInicialFragment"
            app:destination="@id/telaInicialFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/meusPedidosFragment"
        android:name="com.mobile.agregarural.ui.profile.MeusPedidosFragment"
        android:label="Meus Pedidos"
        tools:layout="@layout/fragment_meus_pedidos" />

    <fragment
        android:id="@+id/dadosPessoaisFragment"
        android:name="com.mobile.agregarural.ui.profile.DadosPessoaisFragment"
        android:label="Dados pessoais"
        tools:layout="@layout/fragment_dados_pessoais" />


    <fragment
        android:id="@+id/menuFragment"
        android:name="com.mobile.agregarural.ui.home.MenuFragment"
        android:label="Menu"
        tools:layout="@layout/fragment_menu" />

    <fragment
        android:id="@+id/meusEnderecosFragment"
        android:name="com.mobile.agregarural.ui.profile.MeusEnderecosFragment"
        android:label="Meus endereços"
        tools:layout="@layout/fragment_meus_enderecos" />

    <fragment
        android:id="@+id/telaLoginFragment"
        android:name="com.mobile.agregarural.ui.auth.FragmentLoginFragment">
        <action
            android:id="@+id/action_telaLoginFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/MinhaCooperativaFragment"
        android:name="com.mobile.agregarural.ui.cooperative.MinhaCooperativa"
        />


    <fragment
        android:id="@+id/recuperarSenhaFragment"
        android:name="com.mobile.agregarural.ui.auth.RecuperarSenhaFragment" />

    <fragment
        android:id="@+id/telaCadastro1Fragment"
        android:name="com.mobile.agregarural.ui.auth.TelaCadastro1Fragment">
        <action
            android:id="@+id/action_telaCadastro1_to_telaCadastro2"
            app:destination="@id/telaCadastro2Fragment" />
    </fragment>

    <fragment
        android:id="@+id/telaCadastro2Fragment"
        android:name="com.mobile.agregarural.ui.auth.TelaCadastro2Fragment">
        <action
            android:id="@+id/action_telaCadastro2_to_telaCadastro3"
            app:destination="@id/telaCadastro3Fragment" />
    </fragment>

    <fragment
        android:id="@+id/telaCadastro3Fragment"
        android:name="com.mobile.agregarural.ui.auth.TelaCadastro3Fragment">
        <action
            android:id="@+id/action_telaCadastro3_to_telaCadastro4"
            app:destination="@id/telaCadastro4Fragment" />
    </fragment>

    <fragment
        android:id="@+id/telaProdutoFragment"
        android:name="com.mobile.agregarural.ui.product.TelaProduto"
        android:label="Produto">

        <action
            android:id="@+id/action_telaProdutoFragment_to_carrinhoFragment"
            app:destination="@id/carrinhoFragment" />

        <action
            android:id="@+id/action_telaProdutoFragment_to_telaFinalizacaoPedidoFragment"
            app:destination="@id/telaFinalizacaoPedidoFragment" />

        <action
            android:id="@+id/action_telaProdutoFragment_to_homeFragment"
            app:destination="@id/homeFragment" />

    </fragment>

    <fragment
        android:id="@+id/telaCadastro4Fragment"
        android:name="com.mobile.agregarural.ui.auth.TelaCadastro4Fragment" />

    <fragment
        android:id="@+id/telaFinalizacaoPedidoFragment"
        android:name="com.mobile.agregarural.ui.cart.TelaFinalizaoPedido"
        android:label="Finalização do Pedido">
        <action
            android:id="@+id/action_telaFinalizacaoPedidoFragment_to_telaPagamentoEnderecoFragment"
            app:destination="@id/telaPagamentoEnderecoFragment" />
    </fragment>

    <fragment
        android:id="@+id/telaPagamentoEnderecoFragment"
        android:name="com.mobile.agregarural.ui.cart.TelaPagamentoEndereco"
        android:label="Pagamento e Endereço">
        <action
            android:id="@+id/action_telaPagamentoEnderecoFragment_to_telaPagamentoFragment"
            app:destination="@id/telaPagamentoFragment" />
    </fragment>
    <fragment
        android:id="@+id/carrinhoFragment"
        android:name="com.mobile.agregarural.ui.cart.CarrinhoFragment"
        android:label="Carrinho" />

    <fragment
        android:id="@+id/telaPagamentoFragment"
        android:name="com.mobile.agregarural.ui.cart.TelaPagamento"
        android:label="Pagamento" />
</navigation>